# CreatorCRM Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Cloudflare Worker URL for open/click tracking (optional — emails work without it)
CLOUDFLARE_WORKER_URL=

# Sender display name (shown in recipient's inbox)
SENDER_NAME=Your Name

# Timezone for dashboard display
DISPLAY_TIMEZONE=Asia/Kolkata

# Domain warm-up: max daily emails during warm-up period
# Start with 20, increase weekly. Set to 0 for full limit (1950/day)
#   Week 1: 20  |  Week 2: 50  |  Week 3: 100  |  Week 4: 175
#   Week 5: 250 |  Week 6: 400 |  Week 7: 700  |  Week 8+: 0
WARMUP_DAILY_MAX=20

# Leave blank to auto-generate secure random secrets on first run
SECRET_KEY=
TRACKING_SECRET=
