{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CreatorCRM",
  "version": "0.1.0",
  "identifier": "app.creatorcrm.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns", "icons/icon.png"],
    "resources": {
      "../backend-dist/creatorcrm-backend": "backend"
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    }
  }
}
